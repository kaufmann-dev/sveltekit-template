{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "@sveltejs/opencode"
    ],
    "mcp": {
        "shadcn-svelte": {
            "type": "remote",
            "url": "https://shadcn-svelte.mastra.cloud/api/mcp/shadcn/mcp",
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": ["npx", "-y", "@playwright/mcp@latest"],
            "enabled": false
        },
        "postgres": {
            "type": "local",
            "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "{env:DATABASE_URL}"],
            "enabled": false
        },
        "resend": {
            "type": "local",
            "command": ["npx", "-y", "resend-mcp"],
            "enabled": false,
            "environment": {
                "RESEND_API_KEY": "{env:RESEND_API_KEY}"
            }
        },
        "glitchtip": {
            "type": "remote",
            "url": "{env:GLITCHTIP_MCP_URL}",
            "enabled": false
        }
    }
}
