{
    "$schema": "https://svelte.dev/opencode/schema.json",
    "mcp": {
        "type": "remote",
        "enabled": true
    },
    "subagent": {
        "enabled": true,
        "agents": {
            "svelte-file-editor": {
                "model": "<other-model>",
                "temperature": 1,
                "top_p": 0.7,
                "maxSteps": 20
            }
        }
    },
    "skills": {
        "enabled": false
    },
    "instructions": {
        "enabled": false
    }
}