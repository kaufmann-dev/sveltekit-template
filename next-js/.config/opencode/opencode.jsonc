{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "Astro docs": {
            "type": "remote",
            "url": "https://mcp.docs.astro.build/mcp",
            "enabled": true
        },
        {
            "mcpServers": {
                "next-devtools": {
                    "command": "npx",
                    "args": [
                        "-y",
                        "next-devtools-mcp@latest"
                    ]
                }
            }
        }
    }
}